<!-- src/views/public/index.ejs 简化版 -->
<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/custom.css">
</head>
<body class="bg-gray-50">
    <!-- 导航栏 -->
    <nav class="bg-white shadow-sm">
        <div class="container mx-auto px-4 py-3 flex justify-between items-center">
            <a href="/" class="text-xl font-bold text-gray-800">YC's Blog</a>
            <div class="space-x-4">
                <a href="/" class="text-gray-600 hover:text-gray-900">首页</a>
                <a href="/projects" class="text-gray-600 hover:text-gray-900">项目</a>
                <a href="/lab" class="text-gray-600 hover:text-gray-900">实验室</a>
                <a href="/about" class="text-gray-600 hover:text-gray-900">关于</a>
            </div>
        </div>
    </nav>

    <!-- 英雄区域 -->
    <header class="py-12 bg-gradient-to-r from-blue-50 to-indigo-50">
        <div class="container mx-auto px-4 text-center">
            <h1 class="text-4xl font-bold text-gray-800 mb-4">工程实践与思考记录</h1>
            <p class="text-lg text-gray-600 max-w-2xl mx-auto">
                记录从无人机控制到AI部署的全栈探索，分享技术实践与学习思考。
            </p>
        </div>
    </header>

    <!-- 置顶文章 -->
    <% if (pinnedPosts.length > 0) { %>
    <section class="container mx-auto px-4 py-8">
        <h2 class="text-2xl font-bold text-gray-800 mb-6">📌 置顶文章</h2>
        <div class="grid md:grid-cols-2 gap-6">
            <% pinnedPosts.forEach(post => { %>
            <article class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-lg transition-shadow">
                <% if (post.featuredImage) { %>
                <img src="/<%= post.featuredImage.replace(/\\/g, '/').replace(/^public\//, '') %>" alt="<%= post.title %>" class="w-full h-48 object-cover">
                <% } %>
                <div class="p-6">
                    <div class="flex items-center text-sm text-gray-500 mb-2">
                        <span><%= post.formattedDate %></span>
                        <span class="mx-2">•</span>
                        <span><%= post.metadata ? post.metadata.readTime : 0 %> 分钟阅读</span>
                    </div>
                    <h3 class="text-xl font-bold text-gray-800 mb-3">
                        <a href="/post/<%= post.slug %>" class="hover:text-blue-600"><%= post.title %></a>
                    </h3>
                    <p class="text-gray-600 mb-4"><%= post.excerpt %></p>
                    <div class="flex flex-wrap gap-2">
                        <% post.tags.forEach(tag => { %>
                        <span class="px-3 py-1 bg-blue-100 text-blue-800 text-sm rounded-full"><%= tag %></span>
                        <% }) %>
                    </div>
                </div>
            </article>
            <% }) %>
        </div>
    </section>
    <% } %>

    <!-- 文章列表 -->
    <main class="container mx-auto px-4 py-8">
        <h2 class="text-2xl font-bold text-gray-800 mb-6">📝 最新文章</h2>
        <div class="space-y-8">
            <% posts.forEach(post => { %>
            <article class="bg-white rounded-lg shadow-sm p-6 hover:shadow-md transition-shadow">
                <div class="flex flex-col md:flex-row md:items-start gap-6">
                    <% if (post.featuredImage) { %>
                    <div class="md:w-1/3">
                        <img src="/<%= post.featuredImage.replace(/\\/g, '/').replace(/^public\//, '') %>" alt="<%= post.title %>"
                             class="w-full h-48 md:h-40 object-cover rounded-lg">
                    </div>
                    <% } %>
                    <div class="<%= post.featuredImage ? 'md:w-2/3' : 'w-full' %>">
                        <div class="flex items-center text-sm text-gray-500 mb-2">
                            <span class="px-3 py-1 bg-gray-100 text-gray-800 rounded-full text-xs">
                                <%= post.category %>
                            </span>
                            <span class="mx-3">•</span>
                            <span><%= post.formattedDate %></span>
                            <span class="mx-3">•</span>
                            <span><%= post.metadata ? post.metadata.readTime : 0 %> 分钟阅读</span>
                        </div>
                        <h3 class="text-xl font-bold text-gray-800 mb-3">
                            <a href="/post/<%= post.slug %>" class="hover:text-blue-600"><%= post.title %></a>
                        </h3>
                        <p class="text-gray-600 mb-4"><%= post.excerpt %></p>
                        <div class="flex justify-between items-center">
                            <div class="flex flex-wrap gap-2">
                                <% post.tags.forEach(tag => { %>
                                <a href="/tag/<%= tag %>"
                                   class="px-3 py-1 bg-blue-50 text-blue-700 text-sm rounded-full hover:bg-blue-100">
                                    <%= tag %>
                                </a>
                                <% }) %>
                            </div>
                            <a href="/post/<%= post.slug %>"
                               class="text-blue-600 hover:text-blue-800 font-medium">
                                阅读全文 →
                            </a>
                        </div>
                    </div>
                </div>
            </article>
            <% }) %>
        </div>

        <!-- 分页 -->
        <% if (totalPages > 1) { %>
        <div class="flex justify-center mt-12">
            <nav class="flex items-center space-x-2">
                <% if (hasPrevPage) { %>
                <a href="/?page=<%= currentPage - 1 %>"
                   class="px-4 py-2 bg-white border border-gray-300 rounded-lg hover:bg-gray-50">
                    上一页
                </a>
                <% } %>

                <% for (let i = 1; i <= totalPages; i++) { %>
                    <% if (i === currentPage) { %>
                    <span class="px-4 py-2 bg-blue-600 text-white rounded-lg">
                        <%= i %>
                    </span>
                    <% } else if (i === 1 || i === totalPages || (i >= currentPage - 2 && i <= currentPage + 2)) { %>
                    <a href="/?page=<%= i %>"
                       class="px-4 py-2 bg-white border border-gray-300 rounded-lg hover:bg-gray-50">
                        <%= i %>
                    </a>
                    <% } else if (i === currentPage - 3 || i === currentPage + 3) { %>
                    <span class="px-4 py-2 text-gray-500">...</span>
                    <% } %>
                <% } %>

                <% if (hasNextPage) { %>
                <a href="/?page=<%= currentPage + 1 %>"
                   class="px-4 py-2 bg-white border border-gray-300 rounded-lg hover:bg-gray-50">
                    下一页
                </a>
                <% } %>
            </nav>
        </div>
        <% } %>
    </main>

    <!-- 页脚 -->
    <footer class="bg-gray-800 text-white py-8 mt-12">
        <div class="container mx-auto px-4">
            <div class="flex flex-col md:flex-row justify-between items-center">
                <div class="mb-4 md:mb-0">
                    <h3 class="text-xl font-bold mb-2">YC's Engineering Blog</h3>
                    <p class="text-gray-400">记录技术探索，分享工程实践</p>
                </div>
                <div class="flex space-x-6">
                    <a href="/admin" class="text-gray-400 hover:text-white">管理面板</a>
                    <a href="/rss.xml" class="text-gray-400 hover:text-white">RSS订阅</a>
                    <a href="mailto:your.email@example.com" class="text-gray-400 hover:text-white">联系我</a>
                </div>
            </div>
            <div class="border-t border-gray-700 mt-6 pt-6 text-center text-gray-500 text-sm">
                <p>© <%= new Date().getFullYear() %> Yare Cosmosky. 基于Node.js + MongoDB构建。</p>
                <p class="mt-1">服务器状态: <span class="text-green-400">● 在线</span> | TCP端口: 3001</p>
            </div>
        </div>
    </footer>

    <!-- TCP连接状态指示器 -->
    <div id="tcp-status" class="fixed bottom-4 right-4 bg-gray-800 text-white px-4 py-2 rounded-lg shadow-lg hidden">
        <div class="flex items-center">
            <span class="w-2 h-2 bg-green-500 rounded-full mr-2 animate-pulse"></span>
            <span>TCP连接已就绪</span>
        </div>
    </div>

    <script>
        // 检查TCP连接状态
        function checkTCPStatus() {
            fetch('/api/tcp-status')
                .then(response => response.json())
                .then(data => {
                    const statusEl = document.getElementById('tcp-status');
                    if (data.connected) {
                        statusEl.classList.remove('hidden');
                    } else {
                        statusEl.classList.add('hidden');
                    }
                });
        }

        // 每30秒检查一次
        setInterval(checkTCPStatus, 30000);
        checkTCPStatus();
    </script>
</body>
</html>
