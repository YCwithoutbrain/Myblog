<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <title><%= title %> - Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
</head>
<body class="bg-gray-100 min-h-screen">
    <nav class="bg-gray-800 text-white p-4 shadow-lg flex justify-between items-center">
        <h1 class="text-2xl font-bold">Blog Admin</h1>
        <div class="space-x-6">
            <a href="/admin/posts" class="text-gray-300 hover:text-white transition">返回列表</a>
        </div>
    </nav>
    <div class="container mx-auto p-6 max-w-4xl">
        <div class="bg-white rounded-lg shadow-lg p-8">
            <h2 class="text-3xl font-bold mb-8 text-gray-800 border-b pb-4"><%= title %></h2>
            <% if (locals.error && locals.error.length > 0) { %>
                <div class="bg-red-100 border-l-4 border-red-500 text-red-700 p-4 mb-6 rounded shadow">
                    <p><%= locals.error[0] %></p>
                </div>
            <% } %>
            <form action="<%= action %>" method="POST" enctype="multipart/form-data" class="space-y-6">
                <div>
                    <label class="block text-gray-700 font-bold mb-2 text-lg">文章标题</label>
                    <input type="text" name="title" value="<%= (locals.post && locals.post.title) ? locals.post.title : '' %>" required class="w-full border border-gray-300 rounded px-4 py-3 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition">
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-gray-700 font-bold mb-2">分类</label>
                        <select name="category" required class="w-full border border-gray-300 rounded px-4 py-3 focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white">
                            <option value="blog" <%= (locals.post && locals.post.category === 'blog') ? 'selected' : '' %>>Blog</option>
                            <option value="project" <%= (locals.post && locals.post.category === 'project') ? 'selected' : '' %>>Project</option>
                            <option value="note" <%= (locals.post && locals.post.category === 'note') ? 'selected' : '' %>>Note</option>
                            <option value="lab" <%= (locals.post && locals.post.category === 'lab') ? 'selected' : '' %>>Lab</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-gray-700 font-bold mb-2">标签（逗号分隔）</label>
                        <input type="text" name="tags" value="<%= (locals.post && locals.post.tags) ? locals.post.tags.join(', ') : '' %>" class="w-full border border-gray-300 rounded px-4 py-3 focus:outline-none focus:ring-2 focus:ring-blue-500">
                    </div>
                </div>
                <div>
                    <label class="block text-gray-700 font-bold mb-2">Slug（若不填则自动生成）</label>
                    <input type="text" name="slug" value="<%= (locals.post && locals.post.slug) ? locals.post.slug : '' %>" placeholder="e.g. my-first-post" class="w-full border border-gray-300 rounded px-4 py-3 focus:outline-none focus:ring-2 focus:ring-blue-500">
                </div>
                <div>
                    <label class="block text-gray-700 font-bold mb-2">摘要</label>
                    <textarea name="excerpt" rows="3" class="w-full border border-gray-300 rounded px-4 py-3 focus:outline-none focus:ring-2 focus:ring-blue-500"><%= (locals.post && locals.post.excerpt) ? locals.post.excerpt : '' %></textarea>
                </div>
                <div>
                    <label class="block text-gray-700 font-bold mb-2 text-lg">正文 (Markdown)</label>
                    <textarea name="content" rows="16" required class="w-full border border-gray-300 rounded px-4 py-3 focus:outline-none focus:ring-2 focus:ring-blue-500 font-mono text-sm shadow-inner"><%= (locals.post && locals.post.content) ? locals.post.content : '' %></textarea>
                </div>
                <div class="bg-gray-50 p-6 rounded-lg border border-gray-200">
                    <label class="block text-gray-700 font-bold mb-4">封面图片</label>
                    <% if (locals.post && locals.post.featuredImage) { %>
                        <div class="mb-6 relative w-64">
                            <img src="/<%= locals.post.featuredImage %>" alt="Current cover" class="w-full h-40 object-cover rounded shadow-md border">
                        </div>
                    <% } %>
                    <input type="file" name="featuredImage" accept="image/*">
                </div>
                <div class="bg-blue-50 p-6 rounded-lg border border-blue-100 flex flex-wrap items-center space-x-10">
                    <label class="flex items-center cursor-pointer">
                        <input type="checkbox" name="isPublished" class="form-checkbox h-5 w-5 text-blue-600 rounded focus:ring-blue-500" <%= (!locals.post || locals.post.isPublished) ? 'checked' : '' %>>
                        <span class="ml-3 text-gray-700 font-medium select-none">已发布</span>
                    </label>
                    <label class="flex items-center cursor-pointer">
                        <input type="checkbox" name="isPinned" class="form-checkbox h-5 w-5 text-yellow-500 rounded focus:ring-yellow-500" <%= (locals.post && locals.post.isPinned) ? 'checked' : '' %>>
                        <span class="ml-3 text-gray-700 font-medium select-none">置顶文章</span>
                    </label>
                </div>
                <div class="flex justify-end pt-6 border-t mt-8">
                    <a href="/admin/posts" class="px-6">
                        取消
                    </a>
                    <button type="submit" class="px-8 py-3 bg-blue-600 text-white rounded shadow-md hover:bg-blue-700 transition font-medium text-lg">保存文章</button>
                </div>
            </form>
        </div>
    </div>
</body>
</html>