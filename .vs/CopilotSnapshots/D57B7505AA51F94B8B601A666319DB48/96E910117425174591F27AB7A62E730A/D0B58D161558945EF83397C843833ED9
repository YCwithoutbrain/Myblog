const mongoose = require('mongoose');

const postSchema = new mongoose.Schema({
    title: {
        type: String,
        required: true,
        trim: true
    },
    slug: {
        type: String,
        required: true,
        unique: true,
        lowercase: true
    },
    content: {
        type: String,
        required: true
    },
    excerpt: {
        type: String,
        maxlength: 200
    },
    category: {
        type: String,
        enum: ['blog', 'project', 'note', 'lab'],
        default: 'blog'
    },
    tags: [{
        type: String,
        lowercase: true
    }],
    isPinned: {
        type: Boolean,
        default: false
    },
    isPublished: {
        type: Boolean,
        default: true
    },
    featuredImage: String,
    author: {
        type: mongoose.Schema.Types.ObjectId,
        ref: 'User'
    },
    views: {
        type: Number,
        default: 0
    },
    metadata: {
        wordCount: Number,
        readTime: Number,
        lastEdited: Date
    }
}, {
    timestamps: true,
    toJSON: { virtuals: true },
    toObject: { virtuals: true }
});

// 虚拟字段：格式化日期
postSchema.virtual('formattedDate').get(function () {
    return this.createdAt.toLocaleDateString('zh-CN', {
        year: 'numeric',
        month: 'long',
        day: 'numeric'
    });
});

// 生成slug
postSchema.pre('save', function (next) {
    if (!this.slug && this.title) {
        this.slug = this.title
            .toLowerCase()
            .replace(/[^\w\s]/g, '')
            .replace(/\s+/g, '-');
    }
    if (typeof next === 'function') next();
});

// 更新编辑时间
postSchema.pre('save', function (next) {
    if (this.isModified('content')) {
        if (!this.metadata) this.metadata = {}; this.metadata.lastEdited = new Date();

        // 计算字数
        if (this.content) {
            const wordCount = this.content.trim().split(/\s+/).length;
            this.metadata.wordCount = wordCount;

            // 计算阅读时间（按200字/分钟）
            this.metadata.readTime = Math.ceil(wordCount / 200);
        }
    }
    if (typeof next === 'function') next();
});

module.exports = mongoose.model('Post', postSchema);
